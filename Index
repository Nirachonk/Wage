<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ระบบบันทึกเวลาทำงาน</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Chakra+Petch:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --deep: #0d0a1a;
    --card: #16112b;
    --card2: #1e1838;
    --border: #3a2f6b;
    --purple1: #7c3aed;
    --purple2: #9d5cf6;
    --purple3: #c084fc;
    --accent: #e879f9;
    --gold: #fbbf24;
    --green: #34d399;
    --red: #f87171;
    --text: #f0ebff;
    --muted: #9585c8;
    --sub: #6b5fa8;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Sarabun', sans-serif;
    background: var(--deep);
    color: var(--text);
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse 80% 50% at 10% -10%, rgba(124,58,237,0.25) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 110%, rgba(157,92,246,0.15) 0%, transparent 60%);
  }

  /* ─── HEADER ─── */
  header {
    background: rgba(22,17,43,0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky; top: 0; z-index: 100;
  }
  .logo {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--purple2), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 0.04em;
  }
  .logo span { font-weight: 400; opacity: 0.7; font-size: 0.85rem; }
  .badge {
    background: linear-gradient(135deg, var(--purple1), var(--accent));
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 99px;
    letter-spacing: 0.06em;
  }

  /* ─── LAYOUT ─── */
  .container { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }

  .tabs {
    display: flex; gap: 4px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 6px;
    margin-bottom: 28px;
    width: fit-content;
  }
  .tab-btn {
    padding: 10px 24px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-family: 'Sarabun', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: 10px;
    cursor: pointer;
    transition: all .2s;
  }
  .tab-btn.active {
    background: linear-gradient(135deg, var(--purple1), var(--purple2));
    color: #fff;
    box-shadow: 0 4px 20px rgba(124,58,237,0.4);
  }
  .tab-btn:hover:not(.active) { color: var(--text); background: rgba(255,255,255,0.06); }

  .page { display: none; }
  .page.active { display: block; animation: fadeIn .25s ease; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

  /* ─── CARD ─── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 28px;
    margin-bottom: 20px;
  }
  .card-title {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--purple3);
    margin-bottom: 20px;
    display: flex; align-items: center; gap: 10px;
  }
  .card-title::before { content: ''; display: block; width: 4px; height: 18px; background: linear-gradient(var(--purple1), var(--accent)); border-radius: 2px; }

  /* ─── FORM ─── */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 7px; }
  .form-group.full { grid-column: 1/-1; }
  label { font-size: 0.85rem; font-weight: 500; color: var(--muted); letter-spacing: 0.02em; }
  input, select {
    background: var(--card2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 14px;
    color: var(--text);
    font-family: 'Sarabun', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    width: 100%;
  }
  input:focus, select:focus {
    border-color: var(--purple2);
    box-shadow: 0 0 0 3px rgba(124,58,237,0.2);
  }
  input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.7) sepia(1) saturate(3) hue-rotate(220deg); }
  .time-row { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 8px; }
  .time-sep { color: var(--muted); font-size: 1.1rem; text-align: center; }

  .btn {
    padding: 12px 28px;
    border: none;
    border-radius: 10px;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--purple1), var(--purple2));
    color: #fff;
    box-shadow: 0 4px 20px rgba(124,58,237,0.35);
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(124,58,237,0.5); }
  .btn-secondary {
    background: var(--card2);
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .btn-secondary:hover { border-color: var(--purple2); color: var(--text); }
  .btn-danger { background: rgba(248,113,113,0.15); border: 1px solid rgba(248,113,113,0.3); color: var(--red); }
  .btn-danger:hover { background: rgba(248,113,113,0.25); }
  .form-actions { margin-top: 20px; display: flex; gap: 10px; }

  /* ─── STATS GRID ─── */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
  .stat-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }
  .stat-box::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--purple1), var(--accent));
    border-radius: 14px 14px 0 0;
  }
  .stat-label { font-size: 0.8rem; color: var(--muted); margin-bottom: 6px; }
  .stat-value { font-family: 'Chakra Petch', sans-serif; font-size: 1.6rem; font-weight: 700; color: var(--text); }
  .stat-sub { font-size: 0.78rem; color: var(--sub); margin-top: 4px; }

  /* ─── TABLE ─── */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  thead tr { border-bottom: 2px solid var(--border); }
  th { padding: 12px 16px; text-align: left; font-size: 0.8rem; font-weight: 600; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap; }
  td { padding: 14px 16px; font-size: 0.9rem; border-bottom: 1px solid rgba(58,47,107,0.5); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(124,58,237,0.06); }

  .chip {
    display: inline-flex; align-items: center;
    padding: 3px 10px;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .chip-ot { background: rgba(251,191,36,0.15); color: var(--gold); border: 1px solid rgba(251,191,36,0.3); }
  .chip-normal { background: rgba(52,211,153,0.15); color: var(--green); border: 1px solid rgba(52,211,153,0.3); }
  .chip-holiday { background: rgba(232,121,249,0.15); color: var(--accent); border: 1px solid rgba(232,121,249,0.3); }
  .chip-weekend { background: rgba(248,113,113,0.15); color: var(--red); border: 1px solid rgba(248,113,113,0.3); }

  .emp-name { font-weight: 600; color: var(--purple3); }
  .money { font-family: 'Chakra Petch', sans-serif; font-weight: 600; }
  .money-total { color: var(--gold); }
  .money-normal { color: var(--green); }
  .money-ot { color: var(--accent); }

  .btn-view {
    padding: 6px 14px;
    border: 1px solid var(--purple1);
    background: rgba(124,58,237,0.1);
    color: var(--purple3);
    border-radius: 8px;
    font-family: 'Sarabun', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
  }
  .btn-view:hover { background: rgba(124,58,237,0.25); color: #fff; }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(6px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    max-width: 820px;
    width: 95%;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    animation: modalIn .25s ease;
  }
  @keyframes modalIn { from { opacity:0; transform:scale(0.95); } to { opacity:1; transform:scale(1); } }
  .modal-close {
    position: absolute; top: 16px; right: 16px;
    background: rgba(255,255,255,0.08);
    border: none;
    color: var(--muted);
    width: 32px; height: 32px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    transition: all .2s;
  }
  .modal-close:hover { background: rgba(248,113,113,0.2); color: var(--red); }
  .modal-emp-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
  .emp-avatar {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--purple1), var(--accent));
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
  }
  .modal-emp-name { font-size: 1.2rem; font-weight: 700; color: var(--text); }
  .modal-emp-sub { font-size: 0.85rem; color: var(--muted); margin-top: 2px; }
  .modal-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 20px; }
  .mini-stat {
    background: var(--card2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
  }
  .mini-stat .v { font-family: 'Chakra Petch', sans-serif; font-size: 1.25rem; font-weight: 700; }
  .mini-stat .l { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }

  /* ─── TOAST ─── */
  #toast {
    position: fixed; bottom: 28px; right: 28px;
    background: var(--card);
    border: 1px solid var(--green);
    border-radius: 12px;
    padding: 14px 22px;
    color: var(--green);
    font-weight: 600;
    font-size: 0.9rem;
    z-index: 9999;
    transform: translateY(80px);
    opacity: 0;
    transition: all .3s ease;
    display: flex; align-items: center; gap: 8px;
  }
  #toast.show { transform: translateY(0); opacity: 1; }

  /* ─── EMPTY ─── */
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--sub);
  }
  .empty svg { opacity: 0.3; margin-bottom: 12px; }
  .empty p { font-size: 0.95rem; }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--deep); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  @media(max-width:768px){
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .form-grid { grid-template-columns: 1fr; }
    .form-group.full { grid-column: 1; }
    .modal-stats { grid-template-columns: 1fr 1fr; }
  }
  @media(max-width:480px){
    .stats-grid { grid-template-columns: 1fr; }
    .tabs { width: 100%; }
    .tab-btn { flex: 1; text-align: center; }
  }
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">TimeTrack <span>| ระบบบันทึกเวลาทำงาน</span></div>
  </div>
  <div class="badge">HR SYSTEM</div>
</header>

<div class="container">
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('entry')">📋 บันทึกเวลาทำงาน</button>
    <button class="tab-btn" onclick="switchTab('summary')">📊 สรุปรายงาน</button>
  </div>

  <!-- ─── PAGE: ENTRY ─── -->
  <div id="page-entry" class="page active">
    <div class="card">
      <div class="card-title">กรอกข้อมูลเวลาทำงาน</div>
      <div class="form-grid">
        <div class="form-group full">
          <label>ชื่อ-สกุล พนักงาน</label>
          <input type="text" id="inp-name" placeholder="กรุณากรอกชื่อ-สกุล" autocomplete="off">
        </div>
        <div class="form-group">
          <label>วันที่ทำงาน</label>
          <input type="date" id="inp-date">
        </div>
        <div class="form-group">
          <label>ค่าแรงต่อวัน (บาท)</label>
          <input type="number" id="inp-wage" placeholder="เช่น 500" min="0">
        </div>
        <div class="form-group full">
          <label>เวลาทำงาน</label>
          <div class="time-row">
            <input type="time" id="inp-start" value="08:00">
            <div class="time-sep">—</div>
            <input type="time" id="inp-end" value="17:00">
          </div>
        </div>
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" onclick="addEntry()">✚ บันทึกเวลาทำงาน</button>
        <button class="btn btn-secondary" onclick="clearForm()">ล้างข้อมูล</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">รายการที่บันทึกล่าสุด</div>
      <div class="table-wrap">
        <table id="recent-table">
          <thead>
            <tr>
              <th>ชื่อ-สกุล</th>
              <th>วันที่</th>
              <th>เวลาเข้า</th>
              <th>เวลาออก</th>
              <th>ชม.ปกติ</th>
              <th>ชม.OT</th>
              <th>ประเภท</th>
              <th>ค่าแรง</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="recent-tbody"></tbody>
        </table>
        <div id="recent-empty" class="empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <p>ยังไม่มีรายการบันทึก</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── PAGE: SUMMARY ─── -->
  <div id="page-summary" class="page">
    <div class="stats-grid" id="stats-grid">
      <div class="stat-box">
        <div class="stat-label">พนักงานทั้งหมด</div>
        <div class="stat-value" id="s-emp">0</div>
        <div class="stat-sub">คน</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">รายการทั้งหมด</div>
        <div class="stat-value" id="s-records">0</div>
        <div class="stat-sub">รายการ</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">ชม.ทำงานรวม</div>
        <div class="stat-value" id="s-hours">0</div>
        <div class="stat-sub">ชั่วโมง</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">ค่าแรงรวมทั้งหมด</div>
        <div class="stat-value money-total" id="s-total">฿0</div>
        <div class="stat-sub">บาท</div>
