          </thead>
          <tbody id="summary-tbody"></tbody>
        </table>
        <div id="summary-empty" class="empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p>ยังไม่มีข้อมูลพนักงาน</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ─── MODAL ─── -->
<div class="modal-overlay" id="emp-modal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-emp-header">
      <div class="emp-avatar" id="modal-avatar"></div>
      <div>
        <div class="modal-emp-name" id="modal-name"></div>
        <div class="modal-emp-sub" id="modal-sub"></div>
      </div>
    </div>
    <div class="modal-stats">
      <div class="mini-stat">
        <div class="v money-normal" id="modal-normal-h">0</div>
        <div class="l">ชั่วโมงปกติ</div>
      </div>
      <div class="mini-stat">
        <div class="v money-ot" id="modal-ot-h">0</div>
        <div class="l">ชั่วโมง OT</div>
      </div>
      <div class="mini-stat">
        <div class="v money-total" id="modal-total-pay">฿0</div>
        <div class="l">ค่าแรงรวม</div>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>วันที่</th>
            <th>วัน</th>
            <th>เวลาเข้า</th>
            <th>เวลาออก</th>
            <th>ชม.ปกติ</th>
            <th>ชม.OT</th>
            <th>ประเภท</th>
            <th>ค่าแรง</th>
          </tr>
        </thead>
        <tbody id="modal-tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<div id="toast">✓ <span id="toast-msg"></span></div>

<script>
const DAYS_TH = ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];
let entries = JSON.parse(localStorage.getItem('tt_entries') || '[]');

function save() { localStorage.setItem('tt_entries', JSON.stringify(entries)); }

function fmt(n) { return n.toLocaleString('th-TH', {minimumFractionDigits:2, maximumFractionDigits:2}); }
function fmtH(h) { return h.toFixed(2); }

// ─── CALCULATE WAGES ───
function calcEntry(entry) {
  const [sh, sm] = entry.start.split(':').map(Number);
  const [eh, em] = entry.end.split(':').map(Number);
  const startMin = sh * 60 + sm;
  const endMin   = eh * 60 + em;
  const totalMin = Math.max(0, endMin - startMin);

  const dateObj = new Date(entry.date + 'T00:00:00');
  const dow = dateObj.getDay(); // 0=Sun, 6=Sat
  const isWeekend = dow === 0 || dow === 6;

  const workStart = 8 * 60;   // 08:00
  const workEnd   = 17 * 60;  // 17:00

  let normalHours = 0, otHours = 0;

  if (isWeekend) {
    // All hours on weekend = OT 1.5×
    otHours = totalMin / 60;
  } else {
    // Normal hours: overlap with 08:00–17:00
    const overlapStart = Math.max(startMin, workStart);
    const overlapEnd   = Math.min(endMin, workEnd);
    const normalMin = Math.max(0, overlapEnd - overlapStart);
    normalHours = normalMin / 60;

    // OT hours: after 17:00
    if (endMin > workEnd) {
      otHours = (endMin - Math.max(startMin, workEnd)) / 60;
    }
  }

  const hourlyRate = entry.wage / 8;
  const normalPay  = normalHours * hourlyRate;
  const otPay      = otHours * hourlyRate * 1.5;
  const totalPay   = normalPay + otPay;

  return { normalHours, otHours, normalPay, otPay, totalPay, isWeekend, dow };
}

// ─── RENDER RECENT TABLE ───
function renderRecent() {
  const tbody = document.getElementById('recent-tbody');
  const empty = document.getElementById('recent-empty');
  if (!entries.length) { tbody.innerHTML = ''; empty.style.display = ''; return; }
  empty.style.display = 'none';

  tbody.innerHTML = entries.slice().reverse().slice(0, 30).map((e, ri) => {
    const i = entries.length - 1 - ri;
    const c = calcEntry(e);
    const typeChip = c.isWeekend
      ? '<span class="chip chip-weekend">วันหยุด</span>'
      : c.otHours > 0
        ? '<span class="chip chip-ot">มี OT</span>'
        : '<span class="chip chip-normal">ปกติ</span>';
    return `<tr>
      <td class="emp-name">${e.name}</td>
      <td>${e.date}<br><small style="color:var(--muted)">${DAYS_TH[c.dow]}</small></td>
      <td>${e.start}</td>
      <td>${e.end}</td>
      <td class="money money-normal">${fmtH(c.normalHours)}</td>
      <td class="money money-ot">${fmtH(c.otHours)}</td>
      <td>${typeChip}</td>
      <td class="money money-total">฿${fmt(c.totalPay)}</td>
      <td><button class="btn-danger btn" style="padding:5px 10px;font-size:0.78rem" onclick="deleteEntry(${i})">ลบ</button></td>
    </tr>`;
  }).join('');
}

// ─── RENDER SUMMARY ───
function renderSummary() {
  const tbody = document.getElementById('summary-tbody');
  const empty = document.getElementById('summary-empty');

  // Group by name
  const map = {};
  entries.forEach(e => {
    if (!map[e.name]) map[e.name] = { wage: e.wage, records: [] };
    map[e.name].records.push(e);
    map[e.name].wage = e.wage; // use latest
  });

  const names = Object.keys(map);
  document.getElementById('s-emp').textContent = names.length;
  document.getElementById('s-records').textContent = entries.length;

  let totalHours = 0, grandTotal = 0;

  if (!names.length) {
    tbody.innerHTML = '';
    empty.style.display = '';
    document.getElementById('s-hours').textContent = '0';
    document.getElementById('s-total').textContent = '฿0';
    return;
  }
  empty.style.display = 'none';

  tbody.innerHTML = names.map(name => {
    const g = map[name];
    let nh = 0, oh = 0, np = 0, op = 0;
    g.records.forEach(e => {
      const c = calcEntry(e);
      nh += c.normalHours; oh += c.otHours;
      np += c.normalPay;   op += c.otPay;
    });
    const total = np + op;
    totalHours += nh + oh;
    grandTotal += total;
    return `<tr>
      <td class="emp-name">${name}</td>
      <td>${g.records.length} วัน</td>
      <td class="money money-normal">${fmtH(nh)} ชม.</td>
      <td class="money money-ot">${fmtH(oh)} ชม.</td>
      <td class="money money-normal">฿${fmt(np)}</td>
      <td class="money money-ot">฿${fmt(op)}</td>
      <td class="money money-total">฿${fmt(total)}</td>
      <td><button class="btn-view" onclick="openModal('${name.replace(/'/g,"\\'")}')">ดูรายละเอียด ▸</button></td>
    </tr>`;
  }).join('');

  document.getElementById('s-hours').textContent = fmtH(totalHours);
  document.getElementById('s-total').textContent = '฿' + fmt(grandTotal);
}

// ─── MODAL ───
function openModal(name) {
  const records = entries.filter(e => e.name === name);
  document.getElementById('modal-name').textContent = name;
  document.getElementById('modal-avatar').textContent = name.charAt(0).toUpperCase();
  document.getElementById('modal-sub').textContent = `${records.length} รายการทำงาน`;

  let nh=0, oh=0, np=0, op=0;
  const rows = records.slice().sort((a,b) => a.date.localeCompare(b.date)).map(e => {
    const c = calcEntry(e);
    nh += c.normalHours; oh += c.otHours;
    np += c.normalPay;   op += c.otPay;
    const typeChip = c.isWeekend
      ? '<span class="chip chip-weekend">วันหยุด ×1.5</span>'
      : c.otHours > 0
        ? '<span class="chip chip-ot">มี OT</span>'
        : '<span class="chip chip-normal">ปกติ</span>';
    return `<tr>
      <td>${e.date}</td>
      <td>${DAYS_TH[c.dow]}</td>
      <td>${e.start}</td>
      <td>${e.end}</td>
      <td class="money money-normal">${fmtH(c.normalHours)}</td>
      <td class="money money-ot">${fmtH(c.otHours)}</td>
      <td>${typeChip}</td>
      <td class="money money-total">฿${fmt(c.totalPay)}</td>
    </tr>`;
  });

  document.getElementById('modal-normal-h').textContent = fmtH(nh) + ' ชม.';
  document.getElementById('modal-ot-h').textContent = fmtH(oh) + ' ชม.';
  document.getElementById('modal-total-pay').textContent = '฿' + fmt(np + op);
  document.getElementById('modal-tbody').innerHTML = rows.join('');
  document.getElementById('emp-modal').classList.add('open');
}
function closeModal() { document.getElementById('emp-modal').classList.remove('open'); }
document.getElementById('emp-modal').addEventListener('click', e => { if(e.target === e.currentTarget) closeModal(); });

// ─── ADD ENTRY ───
function addEntry() {
  const name  = document.getElementById('inp-name').value.trim();
  const date  = document.getElementById('inp-date').value;
  const start = document.getElementById('inp-start').value;
  const end   = document.getElementById('inp-end').value;
  const wage  = parseFloat(document.getElementById('inp-wage').value);

  if (!name)  { alert('กรุณากรอกชื่อ-สกุล'); return; }
  if (!date)  { alert('กรุณาเลือกวันที่'); return; }
  if (!start || !end) { alert('กรุณากรอกเวลา'); return; }
  if (isNaN(wage) || wage <= 0) { alert('กรุณากรอกค่าแรงต่อวัน'); return; }
  if (start >= end)  { alert('เวลาออกต้องมากกว่าเวลาเข้า'); return; }

  entries.push({ name, date, start, end, wage });
  save();
  renderRecent();
  renderSummary();
  showToast(`บันทึกเวลาทำงานของ ${name} สำเร็จ`);
}

function deleteEntry(i) {
  if (!confirm('ยืนยันการลบรายการนี้?')) return;
  entries.splice(i, 1);
  save();
  renderRecent();
  renderSummary();
  showToast('ลบรายการแล้ว');
}

function clearForm() {
  document.getElementById('inp-name').value = '';
  document.getElementById('inp-date').value = '';
  document.getElementById('inp-start').value = '08:00';
  document.getElementById('inp-end').value = '17:00';
  document.getElementById('inp-wage').value = '';
}

function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', (i===0) === (tab==='entry')));
  document.getElementById('page-entry').classList.toggle('active', tab==='entry');
  document.getElementById('page-summary').classList.toggle('active', tab==='summary');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ─── INIT ───
const today = new Date().toISOString().split('T')[0];
document.getElementById('inp-date').value = today;
renderRecent();
renderSummary();
</script>
